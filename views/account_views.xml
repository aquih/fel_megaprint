<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record model="ir.ui.view" id="view_move_form">
            <field name="name">account.move.form.inherit.fel_megaprint</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="fel_gt.view_move_form"/>
            <field name="arch" type="xml">
                <data>
                    <button name="button_draft" position="after">
                        <button name="certificar" id="certificar" string="Certificar FEL" type="object" invisible="firma_fel != False"/>
                    </button>
                    <field name="resultado_xml_fel" position="after">
                        <field name="name_pdf_fel" invisible="1"/>
                        <field name="pdf_fel" filename="name_pdf_fel"/>
                    </field>
                </data>
            </field>
        </record>

        <record model="ir.ui.view" id="view_account_journal_form">
            <field name="name">account.journal.form.inherit.fel_megaprint</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="fel_gt.view_account_journal_form"/>
            <field name="arch" type="xml">
                <data>
                    <field name="tipo_documento_fel" position="after">
                    </field>
                </data>
            </field>
        </record>

        <record id="view_company_form" model="ir.ui.view">
            <field name="name">res.company.form.inherit.fel_megaprint</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="fel_gt.view_company_form"/>
            <field name="arch" type="xml">
                <data>
                    <field name="frases_fel" position="after">
                        <field name="usuario_fel"/>
                        <field name="clave_fel"/>
                        <field name="pruebas_fel"/>
                    </field>
                </data>
            </field>
        </record>

    </data>
</openerp>
